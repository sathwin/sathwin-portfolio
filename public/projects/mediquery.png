<svg width="800" height="450" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="mediquery-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2332;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#080E1A;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="450" fill="url(#mediquery-bg)"/>

  <!-- Chat interface -->
  <g transform="translate(200, 80)">
    <rect x="0" y="0" width="400" height="240" rx="12" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>

    <!-- Message bubbles -->
    <g transform="translate(20, 30)">
      <rect x="0" y="0" width="280" height="50" rx="8" fill="#5B8CFF" opacity="0.2"/>
      <text x="20" y="28" font-family="Arial, sans-serif" font-size="14" fill="#5B8CFF">User: What does this scan show?</text>
    </g>

    <g transform="translate(100, 100)">
      <rect x="0" y="0" width="280" height="110" rx="8" fill="#4ECBA0" opacity="0.2"/>
      <text x="20" y="28" font-family="Arial, sans-serif" font-size="14" fill="#4ECBA0">AI: Based on the medical document...</text>
      <circle cx="25" cy="60" r="3" fill="#4ECBA0" opacity="0.5"/>
      <circle cx="25" cy="75" r="3" fill="#4ECBA0" opacity="0.5"/>
      <circle cx="25" cy="90" r="3" fill="#4ECBA0" opacity="0.5"/>
    </g>
  </g>

  <!-- WebSocket indicator -->
  <g transform="translate(320, 340)">
    <circle cx="8" cy="8" r="6" fill="#4ECBA0"/>
    <text x="20" y="12" font-family="Arial, sans-serif" font-size="14" fill="#4ECBA0">Real-time streaming</text>
  </g>

  <!-- Title -->
  <text x="400" y="390" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#EEF4FF" text-anchor="middle">MediQuery AI</text>
  <text x="400" y="420" font-family="Arial, sans-serif" font-size="16" fill="#4ECBA0" text-anchor="middle">Bedrock · ECS Fargate · WebSocket · PHI Compliant</text>
</svg>
