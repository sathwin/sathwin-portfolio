<svg width="800" height="450" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="booktrack-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2332;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#080E1A;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="450" fill="url(#booktrack-bg)"/>

  <!-- Library shelves -->
  <g transform="translate(150, 80)">
    <!-- Shelf 1 -->
    <rect x="0" y="0" width="60" height="100" rx="4" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <rect x="70" y="0" width="60" height="100" rx="4" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <rect x="140" y="0" width="60" height="100" rx="4" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <rect x="210" y="0" width="60" height="100" rx="4" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <rect x="280" y="0" width="60" height="100" rx="4" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <rect x="350" y="0" width="60" height="100" rx="4" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <rect x="420" y="0" width="60" height="100" rx="4" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>

    <!-- Shelf 2 -->
    <rect x="0" y="120" width="60" height="100" rx="4" fill="#1a2332" stroke="#8C9BA5" stroke-width="2" opacity="0.6"/>
    <rect x="70" y="120" width="60" height="100" rx="4" fill="#1a2332" stroke="#8C9BA5" stroke-width="2" opacity="0.6"/>
    <rect x="140" y="120" width="60" height="100" rx="4" fill="#1a2332" stroke="#8C9BA5" stroke-width="2" opacity="0.6"/>
    <rect x="210" y="120" width="60" height="100" rx="4" fill="#1a2332" stroke="#8C9BA5" stroke-width="2" opacity="0.6"/>
    <rect x="280" y="120" width="60" height="100" rx="4" fill="#1a2332" stroke="#8C9BA5" stroke-width="2" opacity="0.6"/>
    <rect x="350" y="120" width="60" height="100" rx="4" fill="#1a2332" stroke="#8C9BA5" stroke-width="2" opacity="0.6"/>
    <rect x="420" y="120" width="60" height="100" rx="4" fill="#1a2332" stroke="#8C9BA5" stroke-width="2" opacity="0.6"/>
  </g>

  <!-- Search bar -->
  <g transform="translate(250, 250)">
    <rect x="0" y="0" width="300" height="50" rx="25" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <circle cx="30" cy="25" r="12" fill="none" stroke="#5B8CFF" stroke-width="2"/>
    <line x1="40" y1="35" x2="48" y2="43" stroke="#5B8CFF" stroke-width="2"/>
    <text x="70" y="32" font-family="Arial, sans-serif" font-size="16" fill="#5B8CFF">Search books...</text>
  </g>

  <!-- Database indicator -->
  <g transform="translate(330, 320)">
    <rect x="0" y="0" width="140" height="40" rx="8" fill="#1a2332" stroke="#8C9BA5" stroke-width="2"/>
    <text x="70" y="27" font-family="Arial, sans-serif" font-size="14" fill="#8C9BA5" text-anchor="middle">PostgreSQL</text>
  </g>

  <!-- Title -->
  <text x="400" y="390" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#EEF4FF" text-anchor="middle">BookTrack Library</text>
  <text x="400" y="420" font-family="Arial, sans-serif" font-size="16" fill="#5B8CFF" text-anchor="middle">React · Node.js · PostgreSQL · JWT Auth</text>
</svg>
