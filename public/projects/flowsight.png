<svg width="800" height="450" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="flowsight-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2332;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#080E1A;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="450" fill="url(#flowsight-bg)"/>

  <!-- Camera feeds -->
  <g transform="translate(100, 80)">
    <rect x="0" y="0" width="140" height="100" rx="8" fill="#1a2332" stroke="#EF9F27" stroke-width="2"/>
    <circle cx="70" cy="50" r="25" fill="none" stroke="#EF9F27" stroke-width="2" opacity="0.6"/>
    <text x="70" y="135" font-family="Arial, sans-serif" font-size="14" fill="#EF9F27" text-anchor="middle">Cam 1</text>
  </g>

  <g transform="translate(280, 80)">
    <rect x="0" y="0" width="140" height="100" rx="8" fill="#1a2332" stroke="#EF9F27" stroke-width="2"/>
    <circle cx="70" cy="50" r="25" fill="none" stroke="#EF9F27" stroke-width="2" opacity="0.6"/>
    <text x="70" y="135" font-family="Arial, sans-serif" font-size="14" fill="#EF9F27" text-anchor="middle">Cam 2</text>
  </g>

  <g transform="translate(460, 80)">
    <rect x="0" y="0" width="140" height="100" rx="8" fill="#1a2332" stroke="#EF9F27" stroke-width="2"/>
    <circle cx="70" cy="50" r="25" fill="none" stroke="#EF9F27" stroke-width="2" opacity="0.6"/>
    <text x="70" y="135" font-family="Arial, sans-serif" font-size="14" fill="#EF9F27" text-anchor="middle">Cam N</text>
  </g>

  <!-- Kafka stream -->
  <g transform="translate(250, 230)">
    <rect x="0" y="0" width="300" height="50" rx="8" fill="#1a2332" stroke="#4ECBA0" stroke-width="2"/>
    <text x="150" y="33" font-family="Arial, sans-serif" font-size="18" fill="#4ECBA0" text-anchor="middle">Kafka Stream</text>
  </g>

  <!-- YOLOv8 -->
  <g transform="translate(300, 300)">
    <rect x="0" y="0" width="200" height="50" rx="8" fill="#1a2332" stroke="#EF9F27" stroke-width="2"/>
    <text x="100" y="33" font-family="Arial, sans-serif" font-size="18" fill="#EF9F27" text-anchor="middle">YOLOv8 · 94.7% mAP</text>
  </g>

  <!-- Title -->
  <text x="400" y="390" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#EEF4FF" text-anchor="middle">FlowSight</text>
  <text x="400" y="420" font-family="Arial, sans-serif" font-size="16" fill="#EF9F27" text-anchor="middle">YOLOv8 · Kafka · K8s · Real-time Detection</text>
</svg>
