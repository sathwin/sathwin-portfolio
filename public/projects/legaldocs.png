<svg width="800" height="450" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="legaldocs-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2332;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#080E1A;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="450" fill="url(#legaldocs-bg)"/>

  <!-- Grid pattern -->
  <g opacity="0.05">
    <line x1="0" y1="150" x2="800" y2="150" stroke="#5B8CFF" stroke-width="1"/>
    <line x1="0" y1="300" x2="800" y2="300" stroke="#5B8CFF" stroke-width="1"/>
    <line x1="200" y1="0" x2="200" y2="450" stroke="#5B8CFF" stroke-width="1"/>
    <line x1="400" y1="0" x2="400" y2="450" stroke="#5B8CFF" stroke-width="1"/>
    <line x1="600" y1="0" x2="600" y2="450" stroke="#5B8CFF" stroke-width="1"/>
  </g>

  <!-- Document icon -->
  <g transform="translate(280, 100)">
    <rect x="0" y="0" width="160" height="200" rx="8" fill="#1a2332" stroke="#4ECBA0" stroke-width="2"/>
    <rect x="20" y="30" width="120" height="8" rx="4" fill="#4ECBA0" opacity="0.6"/>
    <rect x="20" y="50" width="100" height="8" rx="4" fill="#5B8CFF" opacity="0.4"/>
    <rect x="20" y="70" width="110" height="8" rx="4" fill="#5B8CFF" opacity="0.4"/>
    <rect x="20" y="100" width="120" height="8" rx="4" fill="#EF9F27" opacity="0.6"/>
    <rect x="20" y="120" width="80" height="8" rx="4" fill="#5B8CFF" opacity="0.4"/>
    <rect x="20" y="140" width="100" height="8" rx="4" fill="#5B8CFF" opacity="0.4"/>
  </g>

  <!-- Title -->
  <text x="400" y="340" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#EEF4FF" text-anchor="middle">LegalDocs AI</text>
  <text x="400" y="370" font-family="Arial, sans-serif" font-size="16" fill="#4ECBA0" text-anchor="middle">Bedrock · Step Functions · Textract</text>
</svg>
