<svg width="800" height="450" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="chainswap-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2332;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#080E1A;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="450" fill="url(#chainswap-bg)"/>

  <!-- Blockchain links -->
  <g opacity="0.1">
    <line x1="100" y1="225" x2="700" y2="225" stroke="#5B8CFF" stroke-width="2"/>
    <circle cx="200" cy="225" r="8" fill="#5B8CFF"/>
    <circle cx="350" cy="225" r="8" fill="#5B8CFF"/>
    <circle cx="500" cy="225" r="8" fill="#5B8CFF"/>
    <circle cx="650" cy="225" r="8" fill="#5B8CFF"/>
  </g>

  <!-- AMM Pool -->
  <g transform="translate(250, 100)">
    <rect x="0" y="0" width="300" height="140" rx="12" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <text x="150" y="40" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#5B8CFF" text-anchor="middle">Liquidity Pool</text>

    <!-- Token A -->
    <circle cx="100" cy="90" r="30" fill="none" stroke="#5B8CFF" stroke-width="2"/>
    <text x="100" y="98" font-family="Arial, sans-serif" font-size="18" fill="#5B8CFF" text-anchor="middle">ETH</text>

    <!-- Swap arrow -->
    <path d="M 140 90 L 160 90" stroke="#4ECBA0" stroke-width="2" fill="none"/>
    <polygon points="160,90 155,86 155,94" fill="#4ECBA0"/>
    <path d="M 190 90 L 210 90" stroke="#4ECBA0" stroke-width="2" fill="none"/>
    <polygon points="190,90 195,86 195,94" fill="#4ECBA0"/>

    <!-- Token B -->
    <circle cx="250" cy="90" r="30" fill="none" stroke="#5B8CFF" stroke-width="2"/>
    <text x="250" y="98" font-family="Arial, sans-serif" font-size="18" fill="#5B8CFF" text-anchor="middle">DAI</text>
  </g>

  <!-- Smart Contract -->
  <g transform="translate(300, 270)">
    <rect x="0" y="0" width="200" height="50" rx="8" fill="#1a2332" stroke="#5B8CFF" stroke-width="2"/>
    <text x="100" y="33" font-family="Arial, sans-serif" font-size="16" fill="#5B8CFF" text-anchor="middle">Smart Contract · AMM</text>
  </g>

  <!-- Title -->
  <text x="400" y="360" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#EEF4FF" text-anchor="middle">ChainSwap DEX</text>
  <text x="400" y="390" font-family="Arial, sans-serif" font-size="16" fill="#5B8CFF" text-anchor="middle">Solidity · Web3.js · Hardhat · AMM Protocol</text>
</svg>
